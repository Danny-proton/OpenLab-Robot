# ====================== 集群主机配置 ======================
# 目标主机IP列表，逗号分隔。第一个IP为yr master节点，其余为agent节点
# 单机部署示例：CLUSTER_HOSTS="192.168.1.1"
# 多机部署示例：CLUSTER_HOSTS="192.168.1.1,192.168.1.2,192.168.1.3"
# 也可通过命令行 --hosts 参数指定，命令行参数优先级更高
# 不设置时默认使用本机IP
CLUSTER_HOSTS=""

# Python版本（用于远程安装 openYuanrong 依赖）
YR_PYTHON_VERSION="3.11"

# jiuwenswarm 函数代码目录（远程主机上的路径）
# 留空则自动从远程主机pip安装路径推断：$(pip show jiuwenswarm Location)/jiuwenswarm/extensions
# 如果推断失败，需要手动设置此值
YR_FUNC_CODE_DIR=""

# jiuwenswarm 安装包 URL（远程主机未安装 jiuwenswarm 时使用此URL进行pip安装）
# 示例：JIUWENSWARM_PACKAGE_URL="https://example.com/jiuwenswarm-0.1.0-py3-none-any.whl"
# 如果远程主机已安装 jiuwenswarm，此配置不需要设置
JIUWENSWARM_PACKAGE_URL=""

# ====================== 函数服务配置 ======================
# 函数服务名称
FUNC_SVC_NAME="0@jiuwen@swarm"

# 单实例CPU限制（单位：毫核，300=0.3核）
MGR_CPU=300

# 单实例内存限制（单位：Mi）
MGR_MEMORY=600

# 服务最小实例数
MGR_MIN_INSTANCE=1

# 服务最大实例数
MGR_MAX_INSTANCE=10

# 服务并发处理数量/最大并发数
MGR_CONCURRENT_NUM=10

# 沙箱类型（留空为默认沙箱；可配置为 "supervisor" 使用 supervisor 沙箱）
SANDBOX_TYPE=""

# ====================== Gateway配置 ======================
# jiuwenswarm 实例名（留空则使用默认路径 ~/.jiuwenswarm）
# 如果指定了实例名，配置目录变为 ~/.jiuwenswarm-instances/<实例名>
JIUWENSWARM_INSTANCE_NAME=""

# 网关同时向后端发送的最大并发请求数
GATEWAY_CONCURRENCY=1

# 网关调用后端接口的超时时间（秒）
GATEWAY_INVOKE_TIMEOUT=60

# SessionMap 会话映射策略
# 可选值：per_chat_bot（同聊天窗口+机器人共享会话）、per_chat_bot_user（按用户维度隔离会话）
GATEWAY_SESSION_MAP_SCOPE="per_chat_bot_user"

# 扩展包搜索目录（远程主机上的路径，多个目录用分号;分隔）
# 留空则自动从 jiuwenswarm 安装路径推断：<pip_location>/jiuwenswarm/extensions
# 如需自定义，可设置完整路径，多个目录用分号分隔
# 示例：EXTENSION_DIRS="/opt/pip_location/jiuwenswarm/extensions;/opt/my_extensions"
EXTENSION_DIRS=""

# ====================== Gateway独立部署配置 ======================
# 以下配置仅在单独部署 gateway 时需要手动设置
# 如果先部署 openYuanrong 再部署 gateway，这些值会自动获取，无需手动设置

# Master节点IP（单独部署 gateway 时需要指定）
MASTER_NODE_IP=""

# 元戎Frontend端口（单独部署 gateway 时需要指定，默认8888）
FRONTEND_PORT=""

# 函数ID（单独部署 gateway 时需要指定，由 openYuanrong 注册函数后返回）
FUNCTION_ID=""

# ====================== 大模型接口配置 ======================
# 模型厂商标识（如：OpenAI等）
MODEL_PROVIDER=""

# 大模型名称
MODEL_NAME=""

# 大模型API基础地址
API_BASE=""

# 大模型鉴权密钥
API_KEY=""

# ====================== 向量模型接口配置 ======================
# 向量模型名称
EMBED_MODEL=""

# 向量模型API基础地址
EMBED_API_BASE=""

# 向量模型鉴权密钥
EMBED_API_KEY=""
