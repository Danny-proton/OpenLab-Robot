{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Risk Review Output",
  "type": "object",
  "required": ["decision"],
  "properties": {
    "decision": {
      "type": "string",
      "enum": ["pass", "supplement", "reject"]
    },
    "reasons": {
      "type": "array",
      "items": {"type": "string"}
    },
    "supplement_items": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "additionalProperties": false
}
